{
  "name": "personal-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:component",
    "test:unit": "node --test src/utils/__tests__/*.test.js src/constants/__tests__/*.test.js src/components/__tests__/*.test.js",

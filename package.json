    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "vite": "^7.2.4",
    "vitest": "^4.1.10"
  }
}
